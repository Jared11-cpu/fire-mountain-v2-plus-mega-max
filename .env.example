VITE_AMAP_ENABLED=false
VITE_AMAP_KEY=请填写高德地图_Web端_JS_API_Key_不是Web服务Key
VITE_AMAP_SECURITY_CODE=请填写高德地图安全密钥

# VITE_ 变量会编译进浏览器产物，并非服务端秘密。必须创建“Web端（JS API）”Key，
# 同时配置安全密钥与域名白名单；Web服务Key不能用于浏览器 JS API。不要提交真实生产凭据。

# 可选：由你自己的后端代理实时交通服务。前端会 POST TransportPlanRequest，
# 未配置或请求失败时自动使用规则引擎方案，禁止在浏览器环境放置供应商私钥。
VITE_TRANSPORT_API_URL=

# Sites 服务端运行时密钥（不要添加 VITE_ 前缀，也不要提交真实值）：
# AMAP_WEB_SERVICE_KEY=请在 Sites 运行时环境变量中配置高德_Web服务_API_Key

# 后端 AI 供应商（密钥绝对不要添加 VITE_ 前缀）：
AI_PROVIDER=qwen
# DASHSCOPE_API_KEY=请在 Sites 运行时环境变量中配置百炼 API Key
# DASHSCOPE_WORKSPACE_ID=可选的百炼 Workspace ID
# AI_BASE_URL=https://你的WorkspaceId.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
AI_EXTRACT_MODEL=qwen-flash
AI_RECOMMEND_MODEL=qwen-plus

# 可选：逗号分隔的额外跨域前端地址。Sites 同域、GitHub Pages 和本地开发已默认允许。
ALLOWED_ORIGINS=

