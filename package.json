    "@testing-library/user-event": "14.5.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "fake-indexeddb": "6.0.0",
    "jsdom": "25.0.1",
